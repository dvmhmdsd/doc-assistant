{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "gen:api": "swagger-typescript-api generate -p ../specs/001-doc-assistant-rag/contracts/openapi.yaml -o src/api -n generated.ts --no-client --extract-enums --extract-request-params --extract-response-body",
    "analyze": "node ./scripts/check-bundle-size.mjs || echo 'no analyze script'"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "eventsource-parser": "^3.0.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "swagger-typescript-api": "^13.9.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.6"
  }
}
