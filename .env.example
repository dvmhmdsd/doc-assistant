# Doc Assistant — environment template.
# Copy to `.env` (gitignored) and fill in real values.
#
# Source of truth: `src/config.py:Settings`. Every field there is
# represented below. Missing one = startup error (Constitution Principle
# V — single config surface).

# ---- auth -----------------------------------------------------------
# This single-tenant demo has no global auth gate. Per-session
# isolation is enforced via the opaque `session_id` returned by
# `POST /upload` (server-generated via `secrets.token_urlsafe(32)`,
# unguessable); clients echo it on every subsequent call. Production
# deploys MUST front the API with a reverse proxy / API gateway that
# enforces authentication.

# ---- frontend -------------------------------------------------------
# VITE_API_BASE_URL — dev-only proxy target consumed by `frontend/
# vite.config.ts`. In production the SPA is served from the same
# origin as the API (FastAPI mounts `frontend/dist`), so this MUST
# be left empty for a production build.
VITE_API_BASE_URL=

# ---- providers ------------------------------------------------------
# LLM_PROVIDER: anthropic | openai
LLM_PROVIDER=anthropic
# EMBEDDING_PROVIDER: local | openai
EMBEDDING_PROVIDER=local

# Provider-specific keys. Set the one(s) you actually use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional model overrides (leave blank for sensible defaults).
LLM_MODEL=claude-opus-4-7
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- retrieval / chunking ------------------------------------------
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# ---- uploads -------------------------------------------------------
# 25 MiB cap on a single upload (FR-003).
MAX_UPLOAD_BYTES=26214400

# ---- storage paths --------------------------------------------------
# File-backed Chroma database directory. Persisted across container
# restarts via the chroma-data volume in docker-compose.yml.
CHROMA_PERSIST_DIR=./chroma_data
# Temp directory where uploads are spooled before ingestion. Cleaned
# up per FR-016 after ingestion completes.
UPLOAD_TMP_DIR=./uploads_tmp

# ---- retry policy (FR-021 / R-008) ---------------------------------
# Total wall-clock budget per user-facing provider call. After this the
# server surfaces UpstreamUnavailable (502) instead of retrying further.
RETRY_BUDGET_SECONDS=5.0
# Attempt cap (1 initial + up to RETRY_ATTEMPTS-1 retries).
RETRY_ATTEMPTS=3
# Cap on exponential backoff per attempt (seconds).
RETRY_MAX_WAIT=2.0
